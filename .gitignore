# ── Secrets and generated files (NEVER commit) ────────────────────────────────
# Generated by initializeCommand.sh — contains N8N_ENCRYPTION_KEY
.devcontainer/.env

# Generated by initializeCommand.sh — contains SearXNG secret key
.devcontainer/searxng/settings.yml

# ── n8n data directory ─────────────────────────────────────────────────────────
# Only .gitkeep is committed to create the directory in git.
# The SQLite database changes on every workflow execution and is a binary blob
# that would bloat the git history massively.
n8n-data/*.sqlite
n8n-data/*.db

# n8n binary data (file uploads via workflows)
n8n-data/binaryData/

# n8n crash logs
n8n-data/*.log
n8n-data/crash.journal

# n8n node_modules (if any are installed locally)
n8n-data/node_modules/

# ── OS and editor files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
