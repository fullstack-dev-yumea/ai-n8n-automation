# SearXNG Settings — TEMPLATE
#
# This file is committed to git as a template.
# The actual settings.yml is generated by initializeCommand.sh
# (replacing the CHANGE_ME_GENERATED_BY_INIT placeholder with a real
# random secret) and is gitignored.
#
# Do NOT edit this file for deployment tweaks — edit the generated
# .devcontainer/searxng/settings.yml directly instead.

use_default_settings: true

server:
  # Secret key for cookie signing — replaced at codespace init time.
  # NEVER commit the actual generated settings.yml.
  secret_key: "CHANGE_ME_GENERATED_BY_INIT"

  # Disable the rate limiter so n8n can make repeated API calls freely.
  # Fine-grained bot-detection config lives in limiter.toml.
  limiter: false

  image_proxy: true

redis:
  # Valkey is a Redis-compatible drop-in replacement (recommended by SearXNG).
  url: redis://valkey:6379/0

search:
  safe_search: 0
  autocomplete: ""
  default_lang: ""
  # json format is required for n8n HTTP Request node integration.
  # Access: http://searxng:8080/search?q=your+query&format=json
  formats:
    - html
    - json
